---
import Particles from './Particles.jsx';
import TerminalDemo from './TerminalDemo.jsx';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<section class="relative min-h-screen flex items-center overflow-hidden scanlines">
  <div
    class="absolute inset-0 bg-gradient-to-br from-[#0a0a1a] via-[#0d0d2b] to-[#1a0a2e] animate-gradient-sweep bg-[length:200%_200%]"
  />
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(0,212,255,0.08)_0%,transparent_70%)]" />
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,rgba(167,139,250,0.06)_0%,transparent_60%)]" />
  <Particles client:only="preact" />

  <div class="relative z-10 w-full px-6 pt-32 pb-16">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <div class="glass-strong inline-block px-4 py-1.5 mb-6 text-xs font-medium text-accent tracking-widest uppercase">
          Arch Linux &bull; Hyprland
        </div>

        <h1
          id="hero-title"
          class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-extrabold mb-4 tracking-tight leading-[1.05]"
        >
          <span class="gradient-text">HyprSpaceOS</span>
        </h1>

        <p class="text-xl md:text-2xl text-text-secondary font-light mb-3">
          Tuned to the pixel. Shipped with purpose.
        </p>

        <p class="text-text-secondary/60 text-base md:text-lg mb-8 max-w-lg leading-relaxed">
          An Arch Linux experience built around Hyprland — every animation curve
          hand-tuned, every default opinionated, nothing wasted.
        </p>

        <div class="flex flex-col sm:flex-row items-start gap-4">
          <a
            href={`${base}downloads`}
            class="accent-gradient-bg text-white px-8 py-3.5 rounded-full text-base font-semibold hover:opacity-90 transition-opacity shadow-lg inline-block"
            style="box-shadow: 0 0 24px hsl(var(--accent-h), var(--accent-s), var(--accent-l), 0.25);"
          >
            Download Now
          </a>
          <a
            href={`${base}features`}
            class="glass text-text-primary px-8 py-3.5 rounded-full text-base font-medium hover:bg-[rgba(255,255,255,0.08)] transition-all inline-block"
          >
            Explore Features
          </a>
        </div>
      </div>

      <div class="hidden lg:block">
        <TerminalDemo client:load />
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-float z-10">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-text-secondary/40">
      <path d="M7 13l5 5 5-5M7 6l5 5 5-5" />
    </svg>
  </div>
</section>

<script>
  const title = document.getElementById('hero-title');
  if (title) {
    title.addEventListener('mouseenter', () => {
      title.classList.add('glitch');
      setTimeout(() => title.classList.remove('glitch'), 600);
    });
  }
</script>
