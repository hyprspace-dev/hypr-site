---
export interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
}
const { title, subtitle, centered = true } = Astro.props;
---

<div class={`mb-16 ${centered ? 'text-center' : ''}`}>
  <h2 class="text-4xl md:text-5xl font-bold mb-4">{title}</h2>
  {subtitle && (
    <p class="text-text-secondary text-lg max-w-2xl mx-auto">{subtitle}</p>
  )}
</div>
