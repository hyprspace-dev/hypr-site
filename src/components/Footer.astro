---
const year = new Date().getFullYear();

const quickLinks = [
  { label: 'Features', href: '/features' },
  { label: 'About', href: '/about' },
  { label: 'Downloads', href: '/downloads' },
  { label: 'Gallery', href: '/gallery' },
  { label: 'Docs', href: '/docs' },
];

const communityLinks = [
  { label: 'GitHub', href: 'https://github.com/hyprspace-dev' },
  { label: 'Matrix Chat', href: 'https://matrix.to/#/#hyprspaceos:matrix.org' },
  { label: 'Reddit', href: 'https://reddit.com/r/hyprland' },
  { label: 'Discord', href: 'https://discord.gg/hyprland' },
];
---

<footer class="glass rounded-none border-b-0 border-l-0 border-r-0 mt-auto">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <!-- Footer Grid -->
    <div class="grid md:grid-cols-4 gap-8 mb-12">
      <!-- Brand Column -->
      <div>
        <h3 class="text-lg font-bold gradient-text mb-4">HyprSpaceOS</h3>
        <p class="text-text-secondary text-sm leading-relaxed mb-4">
          Arch Linux with Hyprland. Tuned to the pixel. Shipped with purpose.
        </p>
        <p class="text-text-secondary/50 text-xs">
          © {year} HyprSpaceOS Contributors
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-semibold text-text-primary mb-4">Site</h4>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-text-secondary text-sm hover:text-text-primary transition-colors focus:outline-2 focus:outline-offset-2 rounded"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Community Links -->
      <div>
        <h4 class="font-semibold text-text-primary mb-4">Community</h4>
        <ul class="space-y-2">
          {communityLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-text-secondary text-sm hover:text-text-primary transition-colors focus:outline-2 focus:outline-offset-2 rounded"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="font-semibold text-text-primary mb-4">Resources</h4>
        <ul class="space-y-2">
          <li>
            <a
              href="https://wiki.hyprspaceos.org"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-secondary text-sm hover:text-text-primary transition-colors focus:outline-2 focus:outline-offset-2 rounded"
            >
              Wiki
            </a>
          </li>
          <li>
            <a
              href="https://github.com/hyprspace-dev/hypr-site/issues"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-secondary text-sm hover:text-text-primary transition-colors focus:outline-2 focus:outline-offset-2 rounded"
            >
              Report Issues
            </a>
          </li>
          <li>
            <a
              href="https://github.com/hyprspace-dev/hypr-site"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-secondary text-sm hover:text-text-primary transition-colors focus:outline-2 focus:outline-offset-2 rounded"
            >
              Source Code
            </a>
          </li>
          <li>
            <a
              href="https://github.com/hyprspace-dev"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-secondary text-sm hover:text-text-primary transition-colors focus:outline-2 focus:outline-offset-2 rounded"
            >
              Contribute
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Divider -->
    <div class="h-px bg-gradient-to-r from-transparent via-accent/20 to-transparent mb-8" />

    <!-- Bottom Section -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <p class="text-text-secondary/50 text-xs text-center md:text-left">
        HyprSpaceOS is an open-source project licensed under GPL-3.0. Built by the community, for the community.
      </p>
      
      <!-- Social Icons -->
      <div class="flex items-center gap-6">
        <a
          href="https://github.com/hyprspace-dev/hypr-site"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub repository"
          class="text-text-secondary hover:text-text-primary transition-colors focus:outline-2 focus:outline-offset-2 rounded"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
          </svg>
        </a>
        <a
          href="https://matrix.to/#/#hyprspaceos:matrix.org"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Matrix chat"
          class="text-text-secondary hover:text-text-primary transition-colors focus:outline-2 focus:outline-offset-2 rounded"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M.77 0A.77.77 0 000 .77v22.46c0 .425.345.77.77.77h22.46a.77.77 0 00.77-.77V.77a.77.77 0 00-.77-.77zm2.31 4.62h3.08v11.54h6.16v-3.08H6.16V4.62zm11.54 0h-3.08v11.54h-6.16v-3.08H11.7V4.62zm3.08 0h3.08v11.54h-3.08zm0 14.62v-3.08h3.08v3.08z" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
