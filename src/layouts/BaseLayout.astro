---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'HyprSpaceOS — Tuned to the pixel. Shipped with purpose. An Arch Linux experience built around Hyprland.',
  image = '/favicon.svg',
} = Astro.props;
const site = 'https://hyprspace-dev.github.io/hypr-site';

const schema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "HyprSpaceOS",
  "description": "An Arch Linux distribution with Hyprland compositor, pre-configured and optimized for performance.",
  "url": site,
  "image": `${site}/favicon.svg`,
  "applicationCategory": "SystemSoftware",
  "operatingSystem": "Linux",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "softwareVersion": "1.0.0",
  "author": {
    "@type": "Organization",
    "name": "HyprSpaceOS Contributors"
  }
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={`${site}${Astro.url.pathname}`} />
    
    <title>{title} | HyprSpaceOS</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#00d4ff" />
    
    <!-- Preconnect to external resources -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${site}${Astro.url.pathname}`} />
    <meta property="og:title" content={`${title} | HyprSpaceOS`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${site}${image}`} />
    <meta property="og:site_name" content="HyprSpaceOS" />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | HyprSpaceOS`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${site}${image}`} />

    <!-- JSON-LD Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Navbar />
    <main class="flex-1 pt-16">
      <slot />
    </main>
    <Footer />
  </body>
</html>
