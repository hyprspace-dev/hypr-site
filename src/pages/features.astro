---
import BaseLayout from '../layouts/BaseLayout.astro';
import GlassCard from '../components/GlassCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Reveal from '../components/Reveal.astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const showcases = [
  {
    side: 'left',
    badge: 'Compositor',
    title: 'Hyprland, Configured for Speed',
    desc: 'Not stock Hyprland — HyprSpaceOS ships with 200+ lines of curated config. Every bezier curve tuned by hand, every keybind mapped with intention. Blur, shadows, animations, window rules — all pre-configured and ready.',
    highlights: ['Custom bezier curves (overshot, smooth)', '12px rounding with 8px blur / 3 passes', 'Window rules for float, opacity, and positioning', 'Pre-bound keybinds: Super+Q kill, Super+F fullscreen'],
  },
  {
    side: 'right',
    badge: 'Ecosystem',
    title: 'Apps That Belong Together',
    desc: 'Kitty terminal with GPU acceleration. Waybar with custom modules for workspaces, tray, clock, and CPU. Rofi launcher with fuzzy search and clipboard history. Dunst notifications with glass-style popups. They ship together, they work together.',
    highlights: ['Kitty terminal with custom keybinds and theme', 'Waybar: workspaces, system tray, clock, CPU/RAM', 'Rofi launcher with clipboard manager', 'Dunst with glassmorphism notifications'],
  },
  {
    side: 'left',
    badge: 'Foundation',
    title: 'Arch, But You Don\'t Have to Build It',
    desc: 'Arch Linux is the best distro — if you have 3 hours to set it up. HyprSpaceOS gives you the same rolling-release, AUR-powered foundation with a custom Calamares installer, pre-configured Btrfs snapshots, ZRAM compression, and a tuned kernel. No assembly required.',
    highlights: ['Calamares installer (custom branded)', 'Btrfs with automatic snapshots + compression', 'ZRAM for compressed memory swapping', 'Pre-tuned kernel with low-latency desktop patches'],
  },
];

const timeline = [
  { year: 'Kernel', detail: 'Linux 6.14 LTS', active: true },
  { year: 'Compositor', detail: 'Hyprland 0.48.x', active: true },
  { year: 'Display', detail: 'Wayland (no X11 fallback)', active: true },
  { year: 'Boot', detail: 'systemd-boot', active: true },
  { year: 'FS', detail: 'Btrfs + ZRAM', active: true },
  { year: 'PKG', detail: 'pacman + yay', active: true },
  { year: 'Shell', detail: 'Zsh + powerlevel10k', active: true },
  { year: 'Term', detail: 'Kitty', active: true },
  { year: 'Bar', detail: 'Waybar', active: true },
  { year: 'Launch', detail: 'Rofi', active: true },
  { year: 'Notify', detail: 'Dunst', active: true },
  { year: 'Wall', detail: 'swww', active: true },
  { year: 'Clip', detail: 'wl-clipboard + cliphist', active: true },
  { year: 'Shot', detail: 'grim + slurp + swappy', active: true },
];

const comparisons = [
  { aspect: 'Base', hyprspace: true, arch: true, endeavouros: true, garuda: true },
  { aspect: 'Hyprland pre-tuned', hyprspace: true, arch: false, endeavouros: false, garuda: false },
  { aspect: 'Calamares installer', hyprspace: true, arch: false, endeavouros: true, garuda: true },
  { aspect: 'Btrfs snapshots', hyprspace: true, arch: false, endeavouros: false, garuda: true },
  { aspect: 'Glassmorphism theme', hyprspace: true, arch: false, endeavouros: false, garuda: false },
  { aspect: 'AUR pre-configured', hyprspace: true, arch: false, endeavouros: true, garuda: true },
  { aspect: 'Boot under 5s', hyprspace: true, arch: false, endeavouros: false, garuda: false },
  { aspect: 'ZRAM pre-enabled', hyprspace: true, arch: false, endeavouros: false, garuda: false },
];
---

<BaseLayout title="Features" description="HyprSpaceOS — every component chosen with intent. See what's under the hood.">
  <!-- Hero -->
  <section class="relative pt-32 pb-24 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#0a0a1a] via-[#0d0d2b] to-[#1a0a2e] animate-gradient-sweep bg-[length:200%_200%]" />
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(0,212,255,0.06)_0%,transparent_60%)]" />
    <div class="relative z-10 max-w-6xl mx-auto px-6">
      <Reveal>
        <div class="glass-strong inline-block px-4 py-1.5 mb-6 text-xs font-medium text-accent tracking-widest uppercase">
          Everything Included
        </div>
        <h1 class="text-5xl md:text-7xl font-extrabold mb-4 tracking-tight">
          <span class="gradient-text">Features</span>
        </h1>
        <p class="text-text-secondary/60 text-lg md:text-xl max-w-2xl leading-relaxed">
          Every component chosen with intent. From the compositor to the cursor,
          <span class="block mt-1 text-text-secondary/40">nothing is default — everything is deliberate.</span>
        </p>
      </Reveal>
    </div>
  </section>

  <!-- Full-Width Showcases -->
  <section class="py-8 px-6">
    <div class="max-w-6xl mx-auto">
      {showcases.map((s, i) => (
        <Reveal>
          <div class="grid lg:grid-cols-2 gap-12 items-center mb-32 last:mb-0">
            <div class={s.side === 'right' ? 'lg:order-2' : ''}>
              <div class="glass-strong inline-block px-3 py-1 text-[10px] font-medium text-accent tracking-widest uppercase mb-4">
                {s.badge}
              </div>
              <h2 class="text-3xl md:text-4xl font-bold mb-4 text-text-primary leading-tight">
                {s.title}
              </h2>
              <p class="text-text-secondary text-sm md:text-base leading-relaxed mb-6">
                {s.desc}
              </p>
              <ul class="space-y-2">
                {s.highlights.map((h) => (
                  <li class="flex items-start gap-2 text-sm text-text-secondary/80">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0 mt-0.5 text-accent">
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                    {h}
                  </li>
                ))}
              </ul>
            </div>
            <div class={s.side === 'right' ? 'lg:order-1' : ''}>
              <div class="glass overflow-hidden rounded-xl aspect-[4/3] flex items-center justify-center bg-gradient-to-br from-[#0d0d2b] via-[#1a0a2e] to-[#0a0a1a]">
                <div class="text-center p-8">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-text-secondary/20 mx-auto mb-4">
                    <rect x="3" y="3" width="18" height="18" rx="2" />
                    <circle cx="8.5" cy="8.5" r="1.5" />
                    <path d="M21 15l-5-5L5 21" />
                  </svg>
                  <p class="text-text-secondary/40 text-sm">Screenshot</p>
                  <p class="text-text-secondary/20 text-xs mt-1">Replace with actual image</p>
                </div>
              </div>
            </div>
          </div>
        </Reveal>
      ))}
    </div>
  </section>

  <!-- Technical Specs Timeline -->
  <section class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <Reveal>
        <SectionHeading
          title="Stack"
          subtitle="From kernel to clipboard — every layer visible."
        />
      </Reveal>

      <Reveal delay={100}>
        <div class="max-w-4xl mx-auto">
          <div class="relative pl-8 border-l border-glass-border">
            {timeline.map((item, i) => (
              <div class="relative pb-8 last:pb-0">
                <div class={`absolute -left-[25px] top-1 w-3 h-3 rounded-full border-2 ${item.active ? 'bg-accent border-accent' : 'bg-bg-dark border-glass-border'}`} />
                <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6">
                  <span class="text-xs font-bold text-text-secondary/40 uppercase tracking-wider min-w-[80px]">{item.year}</span>
                  <span class="text-sm text-text-primary font-mono">{item.detail}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="py-24 px-6 relative">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(167,139,250,0.04)_0%,transparent_60%)]" />
    <div class="max-w-6xl mx-auto relative z-10">
      <Reveal>
        <SectionHeading
          title="How We Compare"
          subtitle="Other distros are fine. This one is intentional."
        />
      </Reveal>

      <Reveal delay={100}>
        <div class="overflow-x-auto max-w-4xl mx-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-glass-border">
                <th class="text-left py-4 pr-4 text-text-secondary font-medium">Aspect</th>
                <th class="text-center py-4 px-4 text-accent font-semibold">HyprSpaceOS</th>
                <th class="text-center py-4 px-4 text-text-secondary/50 font-medium">Arch</th>
                <th class="text-center py-4 px-4 text-text-secondary/50 font-medium">Endeavour</th>
                <th class="text-center py-4 px-4 text-text-secondary/50 font-medium">Garuda</th>
              </tr>
            </thead>
            <tbody>
              {comparisons.map((row, i) => {
                const cell = (v) => v
                  ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent mx-auto"><polyline points="20 6 9 17 4 12" /></svg>'
                  : '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-text-secondary/20 mx-auto"><path d="M18 6L6 18M6 6l12 12" /></svg>';
                return (
                  <tr class={`${i < comparisons.length - 1 ? 'border-b border-glass-border/40' : ''} hover:bg-white/[0.02] transition-colors`}>
                    <td class="py-3 pr-4 text-text-primary font-medium whitespace-nowrap">{row.aspect}</td>
                    <td class="py-3 px-4 text-center" set:html={cell(row.hyprspace)} />
                    <td class="py-3 px-4 text-center" set:html={cell(row.arch)} />
                    <td class="py-3 px-4 text-center" set:html={cell(row.endevouros)} />
                    <td class="py-3 px-4 text-center" set:html={cell(row.garuda)} />
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </Reveal>

      <Reveal delay={200}>
        <p class="text-center text-text-secondary/30 text-xs mt-6">
          Comparisons based on latest stable releases. Your mileage may vary.
        </p>
      </Reveal>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6">
    <Reveal>
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-5xl font-bold mb-6">
          Seen enough?
        </h2>
        <p class="text-text-secondary text-lg mb-10 max-w-lg mx-auto">
          Download HyprSpaceOS. Free, open source, and built for people who care.
        </p>
        <a
          href={`${base}downloads`}
          class="accent-gradient-bg text-white px-8 py-3.5 rounded-full text-base font-semibold hover:opacity-90 transition-opacity inline-block"
          style="box-shadow: 0 0 24px hsl(var(--accent-h), var(--accent-s), var(--accent-l), 0.25);"
        >
          Download Now
        </a>
      </div>
    </Reveal>
  </section>
</BaseLayout>
