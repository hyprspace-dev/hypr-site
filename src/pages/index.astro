---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import GlassCard from '../components/GlassCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Reveal from '../components/Reveal.astro';
import TerminalDemo from '../components/TerminalDemo.jsx';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const features = [
  {
    title: 'Blazing Fast',
    desc: 'Arch Linux base with Hyprland\'s lightweight compositor. Boot times under 5 seconds.',
    icon: 'zap',
  },
  {
    title: 'Stunning Visuals',
    desc: 'Glassmorphism, smooth animations, blur effects, and vibrant gradients out of the box.',
    icon: 'eye',
  },
  {
    title: 'Your Way',
    desc: 'Full control over every pixel. Choose from editions or build your own from scratch.',
    icon: 'sliders',
  },
];

const icons = {
  zap: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-accent-cyan"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" /></svg>',
  eye: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-accent-purple"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>',
  sliders: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-accent-cyan"><line x1="4" y1="21" x2="4" y2="14" /><line x1="4" y1="10" x2="4" y2="3" /><line x1="12" y1="21" x2="12" y2="12" /><line x1="12" y1="8" x2="12" y2="3" /><line x1="20" y1="21" x2="20" y2="16" /><line x1="20" y1="12" x2="20" y2="3" /><line x1="1" y1="14" x2="7" y2="14" /><line x1="9" y1="8" x2="15" y2="8" /><line x1="17" y1="16" x2="23" y2="16" /></svg>',
};
---

<BaseLayout title="Home" description="HyprSpaceOS — Smooth. Sharp. Spacious. An elegant Arch Linux experience powered by Hyprland.">
  <Hero />

  <section class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <SectionHeading
        title="Built Different"
        subtitle="Every detail crafted for performance and beauty. No compromise."
      />

      <div class="grid md:grid-cols-3 gap-8">
        {features.map((f) => (
          <Reveal>
            <GlassCard>
              <div class="mb-4" set:html={icons[f.icon]} />
              <h3 class="text-xl font-bold mb-3 text-text-primary">{f.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed">{f.desc}</p>
            </GlassCard>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <Reveal>
        <SectionHeading
          title="Try It Now"
          subtitle="See what the terminal greets you with."
        />
      </Reveal>
      <Reveal delay={200}>
        <TerminalDemo client:load />
      </Reveal>
    </div>
  </section>

  <section class="py-24 px-6 relative">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(167,139,250,0.04)_0%,transparent_60%)]" />
    <Reveal>
      <div class="max-w-4xl mx-auto text-center relative z-10">
        <h2 class="text-3xl md:text-5xl font-bold mb-6">
          Ready to <span class="gradient-text">level up</span> your desktop?
        </h2>
        <p class="text-text-secondary text-lg mb-10 max-w-lg mx-auto">
          Join the community. Download HyprSpaceOS and experience Linux reimagined.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href={`${base}downloads`}
            class="accent-gradient-bg text-white px-8 py-3.5 rounded-full text-base font-semibold hover:opacity-90 transition-opacity shadow-lg shadow-accent-cyan/20"
          >
            Get HyprSpaceOS
          </a>
          <a
            href="https://wiki.hyprspaceos.org"
            target="_blank"
            rel="noopener noreferrer"
            class="glass text-text-primary px-8 py-3.5 rounded-full text-base font-medium hover:bg-[rgba(255,255,255,0.08)] transition-all"
          >
            Read the Wiki
          </a>
        </div>
      </div>
    </Reveal>
  </section>
</BaseLayout>
