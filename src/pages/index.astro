---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import GlassCard from '../components/GlassCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Reveal from '../components/Reveal.astro';
import TerminalDemo from '../components/TerminalDemo.jsx';
import GitHubStats from '../components/GitHubStats.jsx';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const features = [
  {
    title: 'Blazing Fast',
    desc: 'Arch base with Hyprland\'s lightweight compositor. Measured boot: 4.2s on a mid-range NVMe. Idle RAM: 486 MB.',
    icon: 'zap',
    offset: 'mt-0',
  },
  {
    title: 'Hand-Tuned Animations',
    desc: 'Every animation curve custom-beziered. 64 layers of keyframe tuning across windows, workspaces, and fades. Feels like butter at 144 fps.',
    icon: 'eye',
    offset: 'mt-8 md:mt-16',
  },
  {
    title: 'Your Way, Shipped',
    desc: 'Full edition or rolling. Pre-configured but not locked down. ~2,700 packages in the repo. The rest is one `yay` away.',
    icon: 'sliders',
    offset: 'mt-0',
  },
];

const icons = {
  zap: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-accent"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" /></svg>',
  eye: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-accent-secondary"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>',
  sliders: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-accent"><line x1="4" y1="21" x2="4" y2="14" /><line x1="4" y1="10" x2="4" y2="3" /><line x1="12" y1="21" x2="12" y2="12" /><line x1="12" y1="8" x2="12" y2="3" /><line x1="20" y1="21" x2="20" y2="16" /><line x1="20" y1="12" x2="20" y2="3" /><line x1="1" y1="14" x2="7" y2="14" /><line x1="9" y1="8" x2="15" y2="8" /><line x1="17" y1="16" x2="23" y2="16" /></svg>',
};
---

<BaseLayout title="Home" description="HyprSpaceOS — Tuned to the pixel. Shipped with purpose. An Arch Linux experience built around Hyprland.">
  <Hero />

  <!-- Speed Run Stats -->
  <section class="py-16 px-6 relative">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(0,212,255,0.03)_0%,transparent_60%)]" />
    <div class="max-w-4xl mx-auto relative z-10">
      <Reveal>
        <div class="flex flex-wrap justify-center gap-4 md:gap-8">
          <div class="glass-strong px-6 py-4 text-center min-w-[140px]">
            <div class="text-3xl font-bold gradient-text">4.2s</div>
            <div class="text-text-secondary/50 text-xs mt-1">Boot time (NVMe)</div>
          </div>
          <div class="glass-strong px-6 py-4 text-center min-w-[140px]">
            <div class="text-3xl font-bold gradient-text">486 MB</div>
            <div class="text-text-secondary/50 text-xs mt-1">Idle RAM</div>
          </div>
          <div class="glass-strong px-6 py-4 text-center min-w-[140px]">
            <div class="text-3xl font-bold gradient-text">~2,700</div>
            <div class="text-text-secondary/50 text-xs mt-1">Packages in repo</div>
          </div>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- Staggered Feature Cards -->
  <section class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <Reveal>
        <SectionHeading
          title="Built Different"
          subtitle="Not another Arch spin. Every decision has a reason."
        />
      </Reveal>

      <div class="grid md:grid-cols-3 gap-8 items-start">
        {features.map((f) => (
          <div class={f.offset}>
            <Reveal>
              <GlassCard>
                <div class="mb-4" set:html={icons[f.icon]} />
                <h3 class="text-xl font-bold mb-3 text-text-primary">{f.title}</h3>
                <p class="text-text-secondary text-sm leading-relaxed">{f.desc}</p>
              </GlassCard>
            </Reveal>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Terminal Demo -->
  <section class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <Reveal>
        <SectionHeading
          title="First Boot"
          subtitle="What greets you when you log in."
        />
      </Reveal>
      <Reveal delay={200}>
        <TerminalDemo client:load />
      </Reveal>
    </div>
  </section>

  <!-- GitHub Stats + CTA -->
  <section class="py-24 px-6 relative">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(167,139,250,0.04)_0%,transparent_60%)]" />
    <Reveal>
      <div class="max-w-4xl mx-auto text-center relative z-10">
        <div class="flex justify-center mb-6">
          <GitHubStats client:load />
        </div>
        <h2 class="text-3xl md:text-5xl font-bold mb-6">
          Ready to <span class="gradient-text">make the switch</span>?
        </h2>
        <p class="text-text-secondary text-lg mb-10 max-w-lg mx-auto">
          Free. Open source. Built for people who care about their desktop.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href={`${base}downloads`}
            class="accent-gradient-bg text-white px-8 py-3.5 rounded-full text-base font-semibold hover:opacity-90 transition-opacity shadow-lg inline-block"
            style="box-shadow: 0 0 24px hsl(var(--accent-h), var(--accent-s), var(--accent-l), 0.25);"
          >
            Get HyprSpaceOS
          </a>
          <a
            href="https://wiki.hyprspaceos.org"
            target="_blank"
            rel="noopener noreferrer"
            class="glass text-text-primary px-8 py-3.5 rounded-full text-base font-medium hover:bg-[rgba(255,255,255,0.08)] transition-all inline-block"
          >
            Read the Wiki
          </a>
        </div>
      </div>
    </Reveal>
  </section>
</BaseLayout>
